# Prism — NVIDIA NIM Edition
# Minimal configuration for production-ready deployment on Render.

# ─── NVIDIA AI Infrastructure ────────────────────────────────────────────────
# Get your key at https://build.nvidia.com/
NVIDIA_API_KEY=

# ─── Database ───────────────────────────────────────────────────────────────
# Recommend Neon (Free Tier) — https://neon.tech/
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=

# ─── Web research ─────────────────────────────────────────────────────────────
# Tavily (1000 free searches/month) — https://tavily.com/
TAVILY_API_KEY=

# ─── Telegram bot (Optional) ──────────────────────────────────────────────────
# Create via @BotFather
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Orchestrator ─────────────────────────────────────────────────────────────
# Set to "1" in production to auto-start research daemons.
PRISM_AUTO_DAEMON=1

# ─── Security ────────────────────────────────────────────────────────────────
# Secret for session signing / auth (Auto-generated if blank in some flows)
SECRET_KEY=
